<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top custom-navbar">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/">
          <i class="bi bi-code-slash"></i> Cognifyz
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a
                class="nav-link <%= activePage==='home' ? 'active' : '' %>"
                href="/"
                >Home</a
              >
            </li>
            <li class="nav-item">
              <a
                class="nav-link <%= activePage==='about' ? 'active' : '' %>"
                href="/about"
                >About</a
              >
            </li>
            <li class="nav-item">
              <a
                class="nav-link <%= activePage==='contact' ? 'active' : '' %>"
                href="/contact"
                >Contact</a
              >
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Page Header -->
    <div class="page-header">
      <div class="container text-center">
        <h1 class="animate-fadeInUp">About This Project</h1>
        <p class="animate-fadeInUp delay-1">
          Learn what Cognifyz Web Tasks is all about
        </p>
      </div>
    </div>

    <!-- About Content -->
    <section class="about-section">
      <div class="container">
        <div class="row align-items-center g-5">
          <!-- Left: Text -->
          <div class="col-12 col-lg-6">
            <span class="section-badge">Our Mission</span>
            <h2 class="section-title mt-2">
              Practical Web Development Training
            </h2>
            <p style="color: #666; line-height: 1.8; margin-bottom: 20px">
              Cognifyz Tasks is an 8-step hands-on internship program designed
              to take you from complete beginner to expert web developer.
            </p>
            <p style="color: #666; line-height: 1.8; margin-bottom: 28px">
              Each task introduces real-world concepts using professional tools
              like VS Code, Node.js, Express, MongoDB, and GitHub.
            </p>

            <!-- Info list -->
            <div class="about-info-list">
              <div class="about-info-item">
                <i class="bi bi-check-circle-fill" style="color: #6c63ff"></i>
                <span>8 Progressive Tasks from Beginner to Expert</span>
              </div>
              <div class="about-info-item">
                <i class="bi bi-check-circle-fill" style="color: #6c63ff"></i>
                <span>Real tools used by professional developers</span>
              </div>
              <div class="about-info-item">
                <i class="bi bi-check-circle-fill" style="color: #6c63ff"></i>
                <span>Everything committed and pushed to GitHub</span>
              </div>
              <div class="about-info-item">
                <i class="bi bi-check-circle-fill" style="color: #6c63ff"></i>
                <span>Full-stack development from frontend to backend</span>
              </div>
            </div>
          </div>

          <!-- Right: Level Cards -->
          <div class="col-12 col-lg-6">
            <div class="level-cards">
              <div class="level-card" style="border-left: 4px solid #e91e8c">
                <div
                  class="level-card-icon"
                  style="background: #fff0f5; color: #e91e8c"
                >
                  <i class="bi bi-1-circle"></i>
                </div>
                <div>
                  <h6>Level 1 — Beginner</h6>
                  <p>HTML, Node.js, EJS, Basic Validation</p>
                </div>
              </div>

              <div class="level-card" style="border-left: 4px solid #6c63ff">
                <div
                  class="level-card-icon"
                  style="background: #f0f0ff; color: #6c63ff"
                >
                  <i class="bi bi-2-circle"></i>
                </div>
                <div>
                  <h6>Level 2 — Intermediate</h6>
                  <p>CSS, Bootstrap, DOM Manipulation</p>
                </div>
              </div>

              <div class="level-card" style="border-left: 4px solid #4caf50">
                <div
                  class="level-card-icon"
                  style="background: #f0fff4; color: #4caf50"
                >
                  <i class="bi bi-3-circle"></i>
                </div>
                <div>
                  <h6>Level 3 — Advanced</h6>
                  <p>REST APIs, MongoDB, Authentication</p>
                </div>
              </div>

              <div class="level-card" style="border-left: 4px solid #ff9800">
                <div
                  class="level-card-icon"
                  style="background: #fff8e1; color: #ff9800"
                >
                  <i class="bi bi-4-circle"></i>
                </div>
                <div>
                  <h6>Level 4 — Expert</h6>
                  <p>OAuth, External APIs, Redis, Caching</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="custom-footer">
      <div class="container text-center">
        <p class="footer-copy">
          © 2024 Cognifyz Web Tasks. Built with Node.js & Bootstrap.
        </p>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
  </body>
</html>
